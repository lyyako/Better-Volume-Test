{
	"geode": "5.5.3",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "nwo5.better_volume",
	"name": "Better Volume",
	"version": "v2.0.0",
	"developers": ["Nwo5","lyyako"],
	"description": "like the alpha mod kinda but cooler :3c",
	"tags": ["offline", "enhancement", "interface", "utility", "customization"],
	"links": {
		"source": "https://github.com/Nwo5-trg/Better-Volume",
		"community": "https://discord.gg/AeFeYWGUxZ"
	},
	"dependencies": {
		"geode.node-ids": ">=1.23.1"
	},
	"incompatibilities": {
		"alphalaneous.volume_input": ">=v1.0.0"
	},
	"resources": {
    "sprites": [
      "resources/*.png"
    ]
    },
	"settings": {
		"colored-bars": {
			"type": "bool",
			"name": "Colored Bars",
			"default": true
		},
		"music-color": {
			"type": "rgb",
			"name": "Music Color",
			"default": "#007dff"
		},
		"sfx-color": {
			"type": "rgb",
			"name": "SFX Color",
			"default": "#00ff7b"
		},
		"mute-button": {
			"type": "bool",
			"name": "Mute Button",
			"default": true
		},
		"mute-button-on-right": {
			"type": "bool",
			"name": "Mute Button On Right",
			"default": true
		},
		"music-text": {
			"type": "string",
			"name": "Music Text",
			"default": "Music:"
		},
		"sfx-text": {
			"type": "string",
			"name": "SFX Text",
			"default": "SFX:"
		}
	}
}
